# ── Version control ──────────────────────────────────
.git/
.gitignore

# ── Python cache ─────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────
venv/
env/
.venv/

# ── Environment variables ─────────────────────────────
.env
.env.*

# ── Application data (not needed in image) ───────────
backend/uploads/
backend/database/

# ── Ollama models (very large, managed via volume) ───
.ollama/

# ── Logs ─────────────────────────────────────────────
*.log
logs/

# ── IDE and OS ────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Tests ─────────────────────────────────────────────
tests/
.pytest_cache/
.coverage
htmlcov/

# ── Docs (not needed in image) ────────────────────────
README.md
docs/